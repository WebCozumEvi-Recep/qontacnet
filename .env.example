# QONTAC.NET — Üretim ortam değişkenleri
# Sunucuda bu dosyayı .env.production olarak kopyalayıp doldurun.
#
# ÖNEMLİ: Docker Compose env_file içeriğinde "$" karakterini interpolasyona
# sokar. Şifrede "$" varsa "$$" olarak yazın (örn: ahM6eK$CXBwc -> ahM6eK$$CXBwc).

# SMTP (e-posta gönderimi)
SMTP_HOST=mail.qontac.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@qontac.net
SMTP_PASSWORD=
SMTP_FROM=info@qontac.net
SMTP_FROM_NAME=QONTAC Network Card

# Bildirim alıcıları
NOTIFY_TO=info@qontac.net

# Veritabanı (üretimde docker postgres servisi)
DATABASE_URL=postgresql://qontac:qontac_db_2026@postgres:5432/qontac?schema=public

# Oturum (JWT) — uzun, rastgele bir değer kullanın
JWT_SECRET=

# QNB Finansbank Sanal POS (PayFor 3DHost)
# Canlı gate: https://vpos.qnbfinansbank.com/Gateway/3DHost.aspx
# Test gate:  https://vpostest.qnbfinansbank.com/Gateway/3DHost.aspx
QNB_MERCHANT_ID=
QNB_USER_CODE=
QNB_MERCHANT_PASS=
QNB_MBR_ID=5
QNB_GATE_URL=https://vpos.qnbfinansbank.com/Gateway/3DHost.aspx

# Ödeme callback adresleri için site kökü
NEXT_PUBLIC_BASE_URL=https://qontac.net
