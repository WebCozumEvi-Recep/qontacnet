// QONTAC.NET — Veritabanı şeması
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Paket {
  BASLANGIC
  PROFESYONEL
  KURUMSAL
}

enum FirmaDurum {
  AKTIF
  DENEME
  ASKIDA
  IPTAL
}

enum LeadKaynak {
  NFC
  QR
  LINK
}

enum AdminRol {
  SUPER_ADMIN
  OPERASYON
  DESTEK
}

enum SiparisDurum {
  HAZIRLANIYOR
  URETIMDE
  KARGODA
  TESLIM
  IPTAL
}

enum BatchDurum {
  URETIMDE
  STOKTA
  TAHSIS
  BITTI
}

enum BasvuruDurum {
  YENI
  ILETISIMDE
  DONUSUM
  KAYIP
}

model Firma {
  id             String     @id @default(cuid())
  ad             String
  email          String     @unique
  passwordHash   String
  telefon        String     @default("")
  adres          String     @default("")
  website        String     @default("")
  sektor         String     @default("")
  logo           String     @default("")
  temsilci       String     @default("")
  paket          Paket      @default(BASLANGIC)
  durum          FirmaDurum @default(DENEME)
  paketBaslangic DateTime   @default(now())
  paketBitis     DateTime?
  mrr            Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  members   Member[]
  templates CardTemplate[]
}

model Member {
  id           String  @id @default(cuid())
  firma        Firma   @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId      String
  ad           String
  soyad        String  @default("")
  email        String  @unique
  passwordHash String
  telefon      String  @default("")
  unvan        String  @default("")
  departman    String  @default("")
  avatar       String  @default("")
  whatsapp     String  @default("")
  linkedin     String  @default("")
  instagram    String  @default("")
  website      String  @default("")
  biyografi    String  @default("")
  aktif        Boolean @default(true)
  kartRenk     String  @default("#00d4ff")
  templateId   String?

  // Kartta görünür alanlar (toggle'lar)
  showWhatsapp  Boolean @default(true)
  showLinkedin  Boolean @default(true)
  showInstagram Boolean @default(true)
  showWebsite   Boolean @default(true)
  showBio       Boolean @default(true)

  goruntulemeSayisi Int @default(0)
  leadSayisi        Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads Lead[]
}

model Admin {
  id           String   @id @default(cuid())
  ad           String
  email        String   @unique
  passwordHash String
  rol          AdminRol @default(SUPER_ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CardTemplate {
  id        String   @id @default(cuid())
  firma     Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId   String
  ad        String
  renk      String   @default("#00d4ff")
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Lead {
  id        String     @id @default(cuid())
  member    Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  String
  ad        String
  email     String     @default("")
  telefon   String     @default("")
  sirket    String     @default("")
  kaynak    LeadKaynak @default(LINK)
  createdAt DateTime   @default(now())
}

// ---- Platform Admin varlıkları ----

model License {
  id          String   @id @default(cuid())
  ad          Paket    @unique
  aylikFiyat  Int
  yillikFiyat Int
  maxUye      Int // -1 = sınırsız
  maxTemplate Int // -1 = sınırsız
  ozellikler  String[]
  renk        String   @default("#00d4ff")
}

model CardBatch {
  id           String     @id @default(cuid())
  kod          String     @unique
  miktar       Int
  uretici      String     @default("")
  uretimTarihi DateTime   @default(now())
  durum        BatchDurum @default(URETIMDE)
  tahsisFirma  String?
  seriPrefix   String     @default("")
  createdAt    DateTime   @default(now())
}

model Order {
  id        String       @id @default(cuid())
  siparisNo String       @unique
  firma     String
  firmaId   String?
  urun      String
  adet      Int
  tutar     Int
  durum     SiparisDurum @default(HAZIRLANIYOR)
  kargoNo   String?
  createdAt DateTime     @default(now())
}

model Application {
  id        String       @id @default(cuid())
  firmaAdi  String
  yetkili   String       @default("")
  email     String       @default("")
  telefon   String       @default("")
  uyeSayisi String       @default("")
  mesaj     String       @default("")
  durum     BasvuruDurum @default(YENI)
  createdAt DateTime     @default(now())
}

model RevenueSnapshot {
  id        String @id @default(cuid())
  sira      Int    @unique
  ay        String
  yil       Int    @default(2026)
  mrr       Int
  yeniFirma Int    @default(0)
  iptal     Int    @default(0)
}
