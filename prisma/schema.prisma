// QONTAC.NET — Veritabanı şeması
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Paket {
  BASLANGIC
  PROFESYONEL
  KURUMSAL
}

enum FirmaDurum {
  AKTIF
  DENEME
  ASKIDA
  IPTAL
}

enum LeadKaynak {
  NFC
  QR
  LINK
}

enum AdminRol {
  SUPER_ADMIN
  OPERASYON
  DESTEK
}

enum SiparisDurum {
  HAZIRLANIYOR
  URETIMDE
  KARGODA
  TESLIM
  IPTAL
}

enum BatchDurum {
  URETIMDE
  STOKTA
  TAHSIS
  BITTI
}

enum BasvuruDurum {
  YENI
  ILETISIMDE
  DONUSUM
  KAYIP
}

enum FirmaModulTip {
  HAKKIMIZDA
  GALERI
  VIDEO
  FORM
  HTML
  TEK_GORSEL
  SSS
  HERO
}

model Firma {
  id             String     @id @default(cuid())
  ad             String
  email          String     @unique
  passwordHash   String
  telefon        String     @default("")
  adres          String     @default("")
  website        String     @default("")
  sektor         String     @default("")
  logo           String     @default("")
  temsilci       String     @default("")
  paket          Paket      @default(BASLANGIC)
  durum          FirmaDurum @default(DENEME)
  paketBaslangic DateTime   @default(now())
  paketBitis     DateTime?
  mrr            Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  resetToken     String?    @unique
  resetExpiry    DateTime?

  members   Member[]
  templates CardTemplate[]
  moduller  FirmaModul[]
  basvurular FormBasvuru[]
}

model FirmaModul {
  id         String        @id @default(cuid())
  firma      Firma         @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId    String
  template   CardTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String
  tip        FirmaModulTip
  sira       Int           @default(0)
  aktif      Boolean       @default(true)
  baslik     String        @default("")
  icerik     Json
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([templateId, sira])
}

model FormBasvuru {
  id        String   @id @default(cuid())
  firma     Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId   String
  modulId   String?
  memberId  String?
  ad        String
  email     String   @default("")
  telefon   String   @default("")
  mesaj     String   @default("")
  okundu    Boolean  @default(false)
  durum     String   @default("yeni")
  notlar    Json     @default("[]")
  createdAt DateTime @default(now())

  @@index([firmaId, createdAt])
}

model Member {
  id           String  @id @default(cuid())
  firma        Firma?  @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId      String?
  ad           String
  soyad        String  @default("")
  email        String  @unique
  passwordHash String
  telefon      String  @default("")
  unvan        String  @default("")
  departman    String  @default("")
  avatar       String  @default("")
  whatsapp     String  @default("")
  linkedin     String  @default("")
  instagram    String  @default("")
  website      String  @default("")
  biyografi    String  @default("")
  aktif        Boolean @default(true)
  kartAktif    Boolean @default(false)  // fiziksel kart aktive edildi mi
  kartRenk     String  @default("#00d4ff")
  templateId   String?

  physicalCard PhysicalCard?

  // Kartta görünür alanlar (toggle'lar)
  showWhatsapp  Boolean @default(true)
  showLinkedin  Boolean @default(true)
  showInstagram Boolean @default(true)
  showWebsite   Boolean @default(true)
  showBio       Boolean @default(true)

  goruntulemeSayisi Int @default(0)
  leadSayisi        Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads Lead[]
}

model Admin {
  id           String   @id @default(cuid())
  ad           String
  email        String   @unique
  passwordHash String
  rol          AdminRol @default(SUPER_ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CardTemplate {
  id        String   @id @default(cuid())
  firma     Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  firmaId   String
  ad        String
  renk      String   @default("#00d4ff")
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())

  moduller  FirmaModul[]
}

model Lead {
  id        String     @id @default(cuid())
  member    Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  String
  ad        String
  email     String     @default("")
  telefon   String     @default("")
  sirket    String     @default("")
  kaynak    LeadKaynak @default(LINK)
  createdAt DateTime   @default(now())
}

// ---- Platform Admin varlıkları ----

model License {
  id          String   @id @default(cuid())
  ad          Paket    @unique
  aylikFiyat  Int
  yillikFiyat Int
  maxUye      Int // -1 = sınırsız
  maxTemplate Int // -1 = sınırsız
  ozellikler  String[]
  renk        String   @default("#00d4ff")
}

model CardBatch {
  id           String     @id @default(cuid())
  kod          String     @unique
  miktar       Int
  uretici      String     @default("")
  uretimTarihi DateTime   @default(now())
  durum          BatchDurum @default(URETIMDE)
  tahsisFirma    String?    // görüntüleme için firma adı
  tahsisFirmaId  String?    // gerçek FK — aktivasyonda kullanılır
  seriPrefix     String     @default("")
  createdAt    DateTime   @default(now())

  physicalCards PhysicalCard[]
}

model PhysicalCard {
  id           String    @id @default(cuid())
  seriNo       String    @unique  // WQR-2026-0001 — üretim seri numarası
  token        String    @unique  // QR URL'deki opak token, seri no içermez
  batch        CardBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId      String
  firmaId      String?            // hangi firmaya tahsis edildi
  member       Member?   @relation(fields: [memberId], references: [id])
  memberId     String?   @unique
  aktif        Boolean   @default(false)
  aktivasyonAt DateTime?
  createdAt    DateTime  @default(now())
}

model Order {
  id        String       @id @default(cuid())
  siparisNo String       @unique
  firma     String
  firmaId   String?
  urun      String
  adet      Int
  tutar     Int
  durum     SiparisDurum @default(HAZIRLANIYOR)
  kargoNo    String?
  birimFiyat Int          @default(0)
  kdvOrani   Int          @default(20)
  indirim    Int          @default(0)
  notlar     String       @default("")
  // Site üzerinden gelen satın alımlar
  kaynak     String       @default("ADMIN") // ADMIN | SITE
  musteriAd  String       @default("")
  email      String       @default("")
  telefon    String       @default("")
  adres      String       @default("")
  // Fatura bilgileri
  faturaTip    String     @default("BIREYSEL") // BIREYSEL | KURUMSAL
  tcKimlik     String     @default("")
  vergiNo      String     @default("")
  vergiDairesi String     @default("")
  firmaUnvan   String     @default("")
  // Ödeme (QNB sanal POS): MANUEL (admin siparişi) | BEKLIYOR | ODENDI | BASARISIZ
  odemeDurum   String     @default("MANUEL")
  odemeRef     String     @default("") // banka AuthCode / TransId
  createdAt  DateTime     @default(now())
}

// Tekil satır: site kimliği ve kod enjeksiyon ayarları (id = "site")
model SiteSettings {
  id                     String   @id @default("site")
  logoUrl                String   @default("")
  logoText               String   @default("QONTAC")
  googleSiteVerification String   @default("")
  headKod                String   @default("") // <head> içine eklenecek kodlar (analytics vb.)
  bodyKod                String   @default("") // <body> sonuna eklenecek kodlar (reklam vb.)
  // Footer iletişim bilgileri
  iletisimEmail          String   @default("info@qontac.net")
  iletisimTelefon        String   @default("+90 (850) 302 40 04")
  iletisimAdres          String   @default("Ümraniye, İstanbul / Türkiye")
  iletisimAciklama       String   @default("Geleceğin networking dünyasında yerinizi alın. Dijital, akıllı ve prestijli.")
  // Sosyal medya linkleri (boş olan footer'da gizlenir)
  sosyalLinkedin         String   @default("")
  sosyalInstagram        String   @default("")
  sosyalX                String   @default("")
  sosyalFacebook         String   @default("")
  sosyalYoutube          String   @default("")
  sosyalWebsite          String   @default("")
  updatedAt              DateTime @updatedAt
}

// Admin tarafından CKEditor ile yönetilen kurumsal/özel sayfalar (Hakkımızda, KVKK vb.)
model CustomPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  baslik    String
  icerik    String   @default("") // CKEditor HTML çıktısı
  aktif     Boolean  @default(true)
  sira      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([aktif, sira])
}

model Product {
  id        String   @id @default(cuid())
  ad        String
  aciklama  String   @default("")
  fiyat     Int      @default(0)
  gorsel    String   @default("")
  aktif     Boolean  @default(true)
  tip       String   @default("NFC_KART")
  sira      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Application {
  id        String       @id @default(cuid())
  firmaAdi  String
  yetkili   String       @default("")
  email     String       @default("")
  telefon   String       @default("")
  uyeSayisi String       @default("")
  mesaj     String       @default("")
  durum     BasvuruDurum @default(YENI)
  createdAt DateTime     @default(now())

  notlar ApplicationNote[]
}

model ApplicationNote {
  id            String      @id @default(cuid())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  icerik        String
  adminAd       String      @default("")
  createdAt     DateTime    @default(now())
}

model RevenueSnapshot {
  id        String @id @default(cuid())
  sira      Int    @unique
  ay        String
  yil       Int    @default(2026)
  mrr       Int
  yeniFirma Int    @default(0)
  iptal     Int    @default(0)
}
